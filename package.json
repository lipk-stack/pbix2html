{
  "name": "pbix2html-studio",
  "private": true,
  "version": "0.1.0",
  "description": "PBIX2HTML Studio - convert Power BI reports into portable interactive HTML dashboards",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "convert:fixture": "pnpm --filter @pbix2html/cli run start"
  },
  "devDependencies": {
    "@pbix2html/dir-schema": "workspace:*",
    "@pbix2html/html-exporter": "workspace:*",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.33.0"
}
